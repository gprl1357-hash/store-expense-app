# Supabase Dashboard > Project Settings > API 에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# 월 예산 (원) - 필요 시 변경
NEXT_PUBLIC_MONTHLY_BUDGET=10000000

# GitHub push 자동화 (선택 — setup-git-auth.sh 로 설정)
# GITHUB_TOKEN=ghp_xxxxxxxx

# 같은 Wi-Fi 휴대폰·태블릿 테스트 (호스트명만 — 포트는 자동 제거됨)
# 터미널: ipconfig getifaddr en0  (Mac Wi-Fi IP 확인)
ALLOWED_DEV_ORIGINS=192.168.45.84

# --- Slack 알림 · 일일 백업 (서버 전용 — NEXT_PUBLIC 금지) ---
# 실제 값은 .env.local 에만 넣으세요 (Git에 올리지 않음)
# SLACK_ENABLED=true
# SLACK_BOT_TOKEN=xoxb-your-bot-token
# SLACK_NOTIFY_CHANNEL_ID=C0123456789
# SLACK_BACKUP_CHANNEL_ID=C0123456789
# CRON_SECRET=your-random-secret-string
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
